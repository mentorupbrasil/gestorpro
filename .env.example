NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=local-development-placeholder
SUPABASE_PROJECT_ID=project-ref-placeholder
# Segredo temporário somente no ambiente do comando de typegen; nunca versionar valor real.
SUPABASE_ACCESS_TOKEN=local-placeholder
DATABASE_URL=postgresql://app_runtime:local-placeholder@127.0.0.1:54322/postgres
